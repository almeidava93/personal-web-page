---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import TagList from "@/components/TagList.astro";

interface Props {
  project: CollectionEntry<"research">;
}

const { project } = Astro.props;
const { title, summary, startDate, endDate, status, tags, links, heroImage } =
  project.data;

const statusStyles: Record<string, string> = {
  ongoing: "bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300",
  completed: "bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300",
  paused: "bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300",
};
---

<BaseLayout title={title} description={summary}>
  <article>
    <header class="mb-8 flex flex-col gap-3">
      <div class="flex flex-wrap items-center gap-3">
        <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
          {title}
        </h1>
        <span
          class:list={[
            "rounded-full px-2.5 py-0.5 text-xs font-medium capitalize",
            statusStyles[status],
          ]}
        >
          {status}
        </span>
      </div>
      <p class="text-sm text-zinc-500 dark:text-zinc-400">
        <FormattedDate date={startDate} />
        {" – "}
        {endDate ? <FormattedDate date={endDate} /> : "present"}
      </p>
      <p class="text-lg text-zinc-600 dark:text-zinc-300">{summary}</p>
      <TagList tags={tags} />
      {
        links.length > 0 && (
          <div class="flex flex-wrap gap-3 pt-1">
            {links.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener"
                class="rounded-md border border-zinc-300 px-3 py-1 text-sm text-zinc-700 transition hover:border-zinc-400 hover:bg-zinc-50 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800"
              >
                {link.label} ↗
              </a>
            ))}
          </div>
        )
      }
    </header>

    {
      heroImage && (
        <Image
          src={heroImage}
          alt=""
          class="mb-8 w-full rounded-lg border border-zinc-200 dark:border-zinc-800"
        />
      )
    }

    <div
      class="prose prose-zinc max-w-none dark:prose-invert prose-a:text-blue-600 dark:prose-a:text-blue-400"
    >
      <slot />
    </div>
  </article>

  <div class="mt-12 border-t border-zinc-200 pt-6 dark:border-zinc-800">
    <a href="/research" class="text-sm text-blue-600 hover:underline dark:text-blue-400">
      ← Back to all research
    </a>
  </div>
</BaseLayout>
