---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import TagList from "@/components/TagList.astro";

const projects = (await getCollection("research")).sort((a, b) => {
  // Ongoing first, then by start date descending.
  const rank = (s: string) => (s === "ongoing" ? 0 : s === "paused" ? 1 : 2);
  const byStatus = rank(a.data.status) - rank(b.data.status);
  if (byStatus !== 0) return byStatus;
  return b.data.startDate.valueOf() - a.data.startDate.valueOf();
});
---

<BaseLayout title="Research" description="Research projects by Vinicius Almeida.">
  <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
    Research
  </h1>
  <p class="mt-3 text-zinc-600 dark:text-zinc-300">
    Projects I am working on or have worked on.
  </p>

  {
    projects.length === 0 ? (
      <p class="mt-8 text-zinc-500 dark:text-zinc-400">No projects yet.</p>
    ) : (
      <ul class="mt-8 grid gap-4 sm:grid-cols-2">
        {projects.map((project) => (
          <li class="flex flex-col rounded-lg border border-zinc-200 p-5 transition hover:border-zinc-300 dark:border-zinc-800 dark:hover:border-zinc-700">
            <a href={`/research/${project.id}`} class="flex flex-1 flex-col">
              <h2 class="font-semibold text-zinc-900 dark:text-zinc-100">
                {project.data.title}
              </h2>
              <p class="mt-1 flex-1 text-sm text-zinc-600 dark:text-zinc-400">
                {project.data.summary}
              </p>
              <p class="mt-3 text-xs uppercase tracking-wide text-zinc-400 dark:text-zinc-500">
                {project.data.status}
                {" · "}
                <FormattedDate date={project.data.startDate} />
              </p>
            </a>
            <div class="mt-3">
              <TagList tags={project.data.tags} />
            </div>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
