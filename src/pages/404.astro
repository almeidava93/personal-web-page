---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Not found" description="Page not found.">
  <div class="py-16 text-center">
    <p class="text-6xl font-bold text-zinc-300 dark:text-zinc-700">404</p>
    <h1 class="mt-4 text-2xl font-semibold text-zinc-900 dark:text-zinc-100">
      Page not found
    </h1>
    <p class="mt-2 text-zinc-600 dark:text-zinc-400">
      The page you are looking for does not exist.
    </p>
    <a
      href="/"
      class="mt-6 inline-block text-blue-600 hover:underline dark:text-blue-400"
    >
      ← Back home
    </a>
  </div>
</BaseLayout>
