---
import BaseLayout from "@/layouts/BaseLayout.astro";

// Career / academic trajectory. Edit these entries directly.
const timeline = [
  {
    period: "2025 – present",
    title: "Your current role",
    org: "Organization",
    detail: "One line about what you do here.",
  },
  {
    period: "2023 – 2025",
    title: "Previous role",
    org: "Organization",
    detail: "One line about what you did here.",
  },
  {
    period: "2019 – 2023",
    title: "Degree",
    org: "University",
    detail: "Field of study.",
  },
];
---

<BaseLayout title="About" description="About Vinicius Almeida — bio and trajectory.">
  <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
    About
  </h1>

  <div class="prose prose-zinc mt-6 max-w-none dark:prose-invert">
    <p>
      Write a couple of paragraphs about who you are, your background, and what
      you focus on. This is the place to give visitors the human context behind
      the research and writing.
    </p>
    <p>
      You can edit this copy directly in <code>src/pages/about.astro</code>, and
      update the trajectory timeline below in the same file.
    </p>
  </div>

  <h2 class="mt-12 text-xl font-semibold text-zinc-900 dark:text-zinc-100">
    Trajectory
  </h2>
  <ol class="mt-6 border-l border-zinc-200 dark:border-zinc-800">
    {
      timeline.map((item) => (
        <li class="relative ml-4 pb-8 last:pb-0">
          <span class="absolute -left-[1.375rem] top-1.5 h-2.5 w-2.5 rounded-full bg-zinc-300 dark:bg-zinc-600" />
          <p class="text-sm text-zinc-500 dark:text-zinc-400">{item.period}</p>
          <p class="font-medium text-zinc-900 dark:text-zinc-100">
            {item.title}
            <span class="font-normal text-zinc-500 dark:text-zinc-400">
              {" · "}
              {item.org}
            </span>
          </p>
          <p class="text-sm text-zinc-600 dark:text-zinc-300">{item.detail}</p>
        </li>
      ))
    }
  </ol>
</BaseLayout>
