---
import { SITE, NAV_LINKS } from "@/consts";
import ThemeToggle from "./ThemeToggle.astro";

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header
  class="sticky top-0 z-40 border-b border-zinc-200/70 bg-white/80 backdrop-blur dark:border-zinc-800/70 dark:bg-zinc-950/80"
>
  <div class="mx-auto flex max-w-3xl items-center justify-between gap-4 px-4 py-3">
    <a href="/" class="font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
      {SITE.title}
    </a>

    <nav class="flex items-center gap-1 text-sm" aria-label="Primary">
      {
        NAV_LINKS.filter((l) => l.href !== "/").map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class:list={[
              "rounded-md px-2.5 py-1.5 transition hover:bg-zinc-100 dark:hover:bg-zinc-800",
              isActive(link.href)
                ? "font-medium text-zinc-900 dark:text-zinc-100"
                : "text-zinc-600 dark:text-zinc-400",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <ThemeToggle />
    </nav>
  </div>
</header>
